{
  "name": "@hardlydifficult/notion",
  "version": "1.0.0",
  "description": "Notion API client with page read/search/update, markdown conversion, and block utilities",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "@vitest/coverage-v8": "4.1.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
