{
  "name": "@hardlydifficult/ai",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.64",
    "@hardlydifficult/date-time": "file:../date-time",
    "ai": "6.0.141",
    "ollama-ai-provider-v2": "3.5.0",
    "undici": "7.24.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hardlydifficult/logger": "file:../logger",
    "@types/node": "25.5.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2",
    "@vitest/coverage-v8": "4.1.2"
  },
  "peerDependencies": {
    "@hardlydifficult/logger": ">=1.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
