{
  "name": "@hardlydifficult/github",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@hardlydifficult/date-time": "file:../date-time",
    "@octokit/rest": "22.0.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "@vitest/coverage-v8": "4.1.5"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
