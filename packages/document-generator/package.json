{
  "name": "@hardlydifficult/document-generator",
  "version": "1.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/node": "25.5.0",
    "vitest": "4.1.0",
    "@vitest/coverage-v8": "4.1.0"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
