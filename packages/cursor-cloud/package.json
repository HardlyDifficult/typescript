{
  "name": "@hardlydifficult/cursor-cloud",
  "version": "1.0.0",
  "description": "Opinionated client for Cursor Cloud remote agents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
